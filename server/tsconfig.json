{
  "compilerOptions": {
    "rootDir": "../server/", // base on path directory of project
    "outDir": "../server/dist", // base on path directory while do prod
    "module": "nodenext",
    "moduleResolution": "nodenext", // declare node use js not ts
    "target": "esnext",
    "types": [],
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*" // without access many dir instead of use '@'
      ]
    },
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "strict": true,
    "jsx": "react-jsx",
    "verbatimModuleSyntax": true,
    "isolatedModules": true,
    "noUncheckedSideEffectImports": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },
  "include": ["./**/*.ts"]
}
